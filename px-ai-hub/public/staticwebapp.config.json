{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/img/*", "/icons/*", "*.js", "*.css", "*.png", "*.svg", "*.json"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "ALLOWALL",
    "Content-Security-Policy": "frame-ancestors https://teams.microsoft.com https://*.teams.microsoft.com https://*.skype.com https://*.azurestaticapps.net",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff2": "font/woff2"
  }
}
